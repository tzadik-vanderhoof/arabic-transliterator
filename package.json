{
  "type": "module",
  "scripts": {
    "build": "esbuild content-script.js --bundle --format=iife --outfile=bundle.js --platform=browser",
    "zip": "npm run build && powershell Compress-Archive -Force -Path manifest.json,bundle.js,background.js,icons -DestinationPath extension.zip",
    "screenshots": "esbuild screenshot-content.js --bundle --format=iife --outfile=screenshot-bundle.js --platform=browser && node take-screenshots.js"
  },
  "dependencies": {
    "cmu-pronouncing-dictionary": "^3.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "puppeteer": "^25.1.0",
    "sharp": "^0.34.5"
  }
}
